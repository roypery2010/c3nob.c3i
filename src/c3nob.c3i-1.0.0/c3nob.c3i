// ----------------------------------------------------------------------------
// Build / dependency checking
// ----------------------------------------------------------------------------


// "Go Rebuild Urself" technology - recompile `source_path` into `binary_path`
// if the binary is older (or missing), then re-exec the rebuilt binary with
// the original argv so the caller sees a fresh build before doing any work.

// ----------------------------------------------------------------------------
// String_Builder primitives (called by the sb_... macros below)
// ----------------------------------------------------------------------------


// Convert the builder into a null-terminated String view (writes a '\0' in
// the buffer and returns a slice that excludes it).

// ----------------------------------------------------------------------------
// Cmd: command-line builder
// ----------------------------------------------------------------------------


// ----------------------------------------------------------------------------
// ======================  M A C R O S  ====================================

// The `$variable` macro-parameter syntax and `$if`/`$endif` colon-form
// compile-time branching follow the c3-lang.org homepage examples.

// Reserve capacity in a dynamic array. Works on any struct with the
// .items / .len / .cap shape. Caller passes the POINTER (e.g. `&my_list`)
// and `$da` is substituted accordingly - do not pass `&&my_list`.
//
// Allocates at 16 bytes per slot, which is the largest element size we use
// (sizeof(String) on 64-bit). This over-allocates for char/int storage but
// keeps the macro simple and generic. For tighter packing, write a
// type-specialized helper.
macro da_reserve($da, $expected)
{
    while ($expected > $da.cap) {
        if ($da.cap == 0) $da.cap = 16;
        $da.cap *= 2;
        void* c3nob_da_tmp = realloc($da.items, $da.cap * 16);
        $da.items = c3nob_da_tmp;
    }
}

// Append a single item.
macro da_append($da, $item)
{
    @da_reserve($da, $da.len + 1);
    $da.items[$da.len++] = $item;
}

macro da_append_many($da, $new_items, $new_items_count)
{
    @da_reserve($da, $da.len + $new_items_count);
    for (usz $i = 0; $i < $new_items_count; $i++) {
        $da.items[$da.len + $i] = ($new_items)[$i];
    }
    $da.len += $new_items_count;
}

macro da_remove_unordered($da, $i)
{
    $da.items[$i] = $da.items[--$da.len];
}

macro da_pop($da)
{
    assert($da.len > 0);
    --$da.len;
}

// Release the array's backing buffer and reset fields to empty.
macro da_free($da)
{
    if ($da.items != null && $da.cap > 0) {
        free($da.items);
        $da.items = null;
        $da.len = 0;
        $da.cap = 0;
    }
}

// ----------------------------------------------------------------------------
// String_Builder macros - thin shims over the sb_append_* primitives
// ----------------------------------------------------------------------------

macro sb_append($sb, char $c)
{
    return sb_append_byte($sb, $c);
}

// ----------------------------------------------------------------------------
// Logging macros - shorter, level-prefilled wrappers around log()
// ----------------------------------------------------------------------------

macro info(String $msg)
{
    log(LogLevel.C3NOB_INFO, $msg);
}

macro warning(String $msg)
{
    log(LogLevel.C3NOB_WARNING, $msg);
}

macro error_msg(String $msg)
{
    log(LogLevel.C3NOB_ERROR, $msg);
}

// ----------------------------------------------------------------------------
// Compiler abstraction: append the preferred C3 compiler command to a Cmd.
//   * Default: "c3c"
//   * To swap (e.g. "clang", or a path to a custom c3c fork), users can:
//       - redefine this function in their own copy of c3nob.c3
//       - or just call `cmd.append("clang")` themselves without this helper
//
// v1 deliberately drops the older `$if $defined(C3NOB_CC)` macro form - that
// path tripped c3c 0.8.x's macro parser; the helper-function form is
// straightforward and portable.
// ----------------------------------------------------------------------------

